# Google Sheets Integration
# Copy this file to .env.local and fill in the values

# Your Google Spreadsheet ID (from the URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Service Account credentials as a JSON string (all in one line)
# Get this from Google Cloud Console > IAM > Service Accounts > Keys > Add Key > JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
